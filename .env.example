ALPACA_API_KEY=replace_me
ALPACA_SECRET_KEY=replace_me
ALPACA_PAPER_TRADE=true

# Hermes container file ownership. Match your host UID/GID so services/hermes-workspace is writable.
HERMES_UID=1000
HERMES_GID=1000

# Optional Jupyter Lab token for the notebooks profile.
# Empty by default because the port is bound to 127.0.0.1 only.
JUPYTER_TOKEN=

# Optional knobs. docker-compose.yml provides safe defaults.
SYMBOL_ALLOWLIST=SPY,QQQ,AAPL,MSFT,NVDA
MAX_NOTIONAL_PER_TRADE=500
MAX_DAILY_TRADES=5
MIN_CONFIDENCE_TO_TRADE=0.58
COOLDOWN_MINUTES=30

# Dev-only. Allows explicit override_action / override_confidence on paper-trading requests.
# Leave true for local paper plumbing tests; set false when you want inference-only decisions.
ALLOW_INFERENCE_OVERRIDE=true
